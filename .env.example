# Claude authentication: this app uses claude-agent-sdk authenticated via
# your Claude Code subscription. Generate a token with `claude setup-token`
# and paste it into the app's auth panel, or set it here:
# CLAUDE_CODE_OAUTH_TOKEN=your-subscription-token

# Financial Modeling Prep (optional, for company profiles + 10-year financials)
# FMP_API_KEY=your-fmp-key

# Tavily API Key (for web search)
# Get your API key from: https://tavily.com
TAVILY_API_KEY=tvly-your-api-key-here

# NewsAPI Key (for market news)
# Get your API key from: https://newsapi.org
NEWS_API_KEY=your-newsapi-key-here

# Twelve Data API Key (for real-time stock data)
# Get your API key from: https://twelvedata.com
TWELVE_DATA_API_KEY=your-twelvedata-key-here

# Firecrawl API Key (for real 10-year financial data scraping in Step 2)
# Get your API key from: https://www.firecrawl.dev/
FIRECRAWL_API_KEY=fc-your-firecrawl-key-here
